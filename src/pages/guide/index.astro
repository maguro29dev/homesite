---
import Base from "@/layouts/Base.astro";
import Card from "@/components/Card.astro";
import { md } from "@/lib/md";
import { guidePage, viewerGuidelines } from "@/data/content";
---

<Base title={guidePage.title} description={guidePage.description}>
  <div class="max-w-2xl mx-auto px-4 py-8 space-y-6">
    <section>
      <h1 class="text-2xl font-black text-brand-dark mb-2">{guidePage.title}</h1>
      <p class="text-brand leading-relaxed" set:html={md(guidePage.intro)} />
    </section>

    <Card class="ring-2 ring-brand-accent/30">
      <div class="rounded-lg bg-brand-50 border-2 border-brand-accent/50 p-4 mb-6 space-y-3">
        <h2 class="font-black text-brand-dark">{viewerGuidelines.coreRule.title}</h2>
        <p class="text-brand font-medium leading-relaxed" set:html={md(viewerGuidelines.coreRule.body)} />
        <p class="text-sm text-brand/80 leading-relaxed" set:html={md(viewerGuidelines.coreRule.hatoNote)} />
        <p class="text-sm text-brand/90 font-medium leading-relaxed" set:html={md(viewerGuidelines.coreRule.snsNote)} />
        <ul class="space-y-2">
          {viewerGuidelines.coreRule.examples.map((ex) => (
            <li class="text-sm text-brand/85 pl-3 border-l-2 border-brand-accent leading-relaxed">
              <span set:html={md(ex)} />
            </li>
          ))}
        </ul>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div>
          <p class="text-xs font-bold text-brand mb-2">してほしいこと</p>
          <ul class="space-y-2">
            {viewerGuidelines.dos.map((item) => (
              <li class="flex gap-2 text-sm text-brand/85">
                <span class="text-brand-dark">✓</span>
                <span set:html={md(item)} />
              </li>
            ))}
          </ul>
        </div>
        <div>
          <p class="text-xs font-bold text-rose-700 mb-2">ご遠慮いただきたいこと</p>
          <ul class="space-y-2">
            {viewerGuidelines.donts.map((item) => (
              <li class="flex gap-2 text-sm text-brand/85">
                <span class="text-rose-600">×</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </Card>

    <p class="text-center text-sm text-brand/70">
      <a href="/" class="text-brand-dark font-bold hover:underline">← home</a>
    </p>
  </div>
</Base>
